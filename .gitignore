# Backlog working files (keep structure)
backlog/doing/*
backlog/failed/*
backlog/handoffs/pending/*
backlog/handoffs/archive/*
!backlog/doing/.gitkeep
!backlog/failed/.gitkeep
!backlog/handoffs/pending/.gitkeep
!backlog/handoffs/archive/.gitkeep

# Agent workspace files (keep structure)
agents/*/workspace/*
!agents/*/workspace/.gitkeep
agents/*/memory/*
!agents/*/memory/.gitkeep